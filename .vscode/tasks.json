{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar Npcap",
            "type": "shell",
            "command": "g++",
            "args": [
                "-Wall",
                "-Wextra",
                "-g3",

                "-I",
                "C:/npcap-sdk/Include",

                "main.cpp",

                "-L",
                "C:/npcap-sdk/Lib/x64",

                "-lwpcap",
                "-lPacket",
                "-lWs2_32",

                "-o",
                "output/main.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}